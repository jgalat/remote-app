{
  "name": "@remote-app/app",
  "version": "0.25.9",
  "description": "A transmission remote session app",
  "main": "expo-router/entry",
  "author": "Jorge Galat <jrgglt@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "repository": {
    "type": "git",
    "url": "https://github.com/jgalat/remote-app"
  },
  "scripts": {
    "dev": "expo start",
    "dev:android": "expo start --android",
    "prebuild": "expo prebuild --clean --platform android",
    "build:android:development": "pnpm dlx --config.ignore-scripts=true eas-cli@18.11.0 build --platform android --local --profile development",
    "build:android:production": "pnpm dlx --config.ignore-scripts=true eas-cli@18.11.0 build --platform android --local --profile production",
    "lint": "eslint --max-warnings=0 .",
    "test:transmission": "pnpm --filter @remote-app/transmission-client test",
    "test:qbittorrent": "pnpm --filter @remote-app/qbittorrent-client test",
    "test:pro": "pnpm --filter @remote-app/pro test",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.1.1",
    "@react-navigation/material-top-tabs": "^7.3.6",
    "@react-navigation/native": "^7.1.6",
    "@remote-app/qbittorrent-client": "workspace:*",
    "@remote-app/transmission-client": "workspace:*",
    "@shopify/react-native-skia": "2.2.12",
    "@tanstack/react-query": "^5.59.13",
    "expo": "~54.0.34",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.8",
    "expo-background-task": "~1.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.8",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.11",
    "expo-font": "~14.0.7",
    "expo-haptics": "~15.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.58.1",
    "react-native": "0.81.5",
    "react-native-actions-sheet": "^0.9.7",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "^3.1.0",
    "react-native-pager-view": "6.9.1",
    "react-native-purchases": "^9.7.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.25.67"
  },
  "optionalDependencies": {
    "@remote-app/pro": "workspace:*"
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./node_modules",
        "./modules",
        "./packages/pro/modules"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@eslint/compat": "^1.3.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  }
}
