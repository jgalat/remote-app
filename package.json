{
  "name": "@remote-app/app",
  "version": "0.27.2",
  "description": "A transmission remote session app",
  "main": "expo-router/entry",
  "author": "Jorge Galat <jrgglt@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "repository": {
    "type": "git",
    "url": "https://github.com/jgalat/remote-app"
  },
  "scripts": {
    "dev": "expo start",
    "dev:android": "expo start --android",
    "prebuild": "expo prebuild --clean --platform android",
    "build:android:development": "pnpm dlx --config.ignore-scripts=true eas-cli@19.1.0 build --platform android --local --profile development",
    "build:android:production": "pnpm dlx --config.ignore-scripts=true eas-cli@19.1.0 build --platform android --local --profile production",
    "lint": "eslint --max-warnings=0 .",
    "test:transmission": "pnpm --filter @remote-app/transmission-client test",
    "test:qbittorrent": "pnpm --filter @remote-app/qbittorrent-client test",
    "test:pro": "pnpm --filter @remote-app/pro test",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.1.1",
    "@remote-app/qbittorrent-client": "workspace:*",
    "@remote-app/transmission-client": "workspace:*",
    "@tanstack/react-query": "^5.59.13",
    "expo": "~56.0.8",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.15",
    "expo-background-task": "~56.0.16",
    "expo-build-properties": "~56.0.16",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-intent-launcher": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.16",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.58.1",
    "react-native": "0.85.3",
    "react-native-actions-sheet": "^0.9.7",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "^3.1.0",
    "react-native-pager-view": "8.0.1",
    "react-native-purchases": "^9.7.6",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-tab-view": "^4.3.0",
    "react-native-worklets": "0.8.3",
    "zod": "^3.25.67"
  },
  "optionalDependencies": {
    "@remote-app/pro": "workspace:*"
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./node_modules",
        "./modules",
        "./packages/pro/modules"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@eslint/compat": "^1.3.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@types/react": "~19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3",
    "vitest": "^4.0.18"
  }
}
