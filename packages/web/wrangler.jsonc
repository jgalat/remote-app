{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "remote-app-web",
  "compatibility_date": "2026-02-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "routes": [
    { "pattern": "remote.jg.ar", "custom_domain": true }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "remote-app-web",
      "database_id": "d1bcb9d3-b997-4ef5-8cac-69c29e36badc"
    }
  ]
}
